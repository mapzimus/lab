+
+  // ── First-launch tutorial (shown once, then never blocks) ───────────────────
+  const TUTORIAL_KEY = 'flipgame.tutorialSeen';
+
+  function maybeShowTutorial(after) {
+    let seen = false;
+    try { seen = localStorage.getItem(TUTORIAL_KEY) === '1'; } catch (_) {}
