+        s.cur = 0;
+        s.worstLoss = Math.max(s.worstLoss, game.lastPenalty);
+      }
+    }
+
+    if (game.practice) {
+      if (game.lastResult === 'MAKE') {
+        streakBannerEl.textContent = game.practiceStreak > 1 ? `✓ ${game.practiceStreak} in a row!` : '✓ Make!';
