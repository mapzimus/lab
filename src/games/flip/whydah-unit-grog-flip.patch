+        d.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,.85);color:#ff5252;font:14px monospace;padding:20px;z-index:9999;white-space:pre-wrap;overflow:auto;';
+        document.body.appendChild(d); return d;
+      })();
+      el.textContent += `[${src?.split('/').pop()}:${line}] ${msg}\n`;
+    };
+
+    // Register the service worker for offline play — only on the deployed
+    // (non-localhost) HTTP(S) site. Skipped on localhost (dev) and file://
+    // (the bundled WebView APK, which is already fully offline).
+    if ('serviceWorker' in navigator && location.protocol.startsWith('http') &&
+        location.hostname !== 'localhost' && location.hostname !== '127.0.0.1') {
+      window.addEventListener('load', () => {
+        navigator.serviceWorker.register('service-worker.js')
+          .then(reg => console.log('SW registered, scope:', reg.scope))
+          .catch(err => console.error('SW registration failed:', err));
+      });
+    }
+  </script>
