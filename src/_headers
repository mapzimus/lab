/*
  Strict-Transport-Security: max-age=31536000
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data:; connect-src 'self'; font-src 'self'; base-uri 'self'; frame-ancestors 'self'; form-action 'self'

# Turf playground: same policy as /* but img-src also allows OSM basemap tiles.
# Both blocks are identical and both detach first, so whether or not the splat
# matches the bare path, exactly one CSP header ships. Scripts/styles stay
# 'self' — Leaflet and Turf are vendored under /lab/turf-playground/vendor/.
/lab/turf-playground/
  ! Content-Security-Policy
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data: https://tile.openstreetmap.org; connect-src 'self'; font-src 'self'; base-uri 'self'; frame-ancestors 'self'; form-action 'self'

/lab/turf-playground/*
  ! Content-Security-Policy
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data: https://tile.openstreetmap.org; connect-src 'self'; font-src 'self'; base-uri 'self'; frame-ancestors 'self'; form-action 'self'

# Train route atlas: same tile allowance as the Turf playground, same
# both-blocks-detach-first pattern. Leaflet is vendored under
# /lab/train-routes/vendor/, the GeoJSON is same-origin.
/lab/train-routes/
  ! Content-Security-Policy
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data: https://tile.openstreetmap.org; connect-src 'self'; font-src 'self'; base-uri 'self'; frame-ancestors 'self'; form-action 'self'

/lab/train-routes/*
  ! Content-Security-Policy
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data: https://tile.openstreetmap.org; connect-src 'self'; font-src 'self'; base-uri 'self'; frame-ancestors 'self'; form-action 'self'

/data/*
  Cache-Control: public, max-age=3600

/styles.css
  Cache-Control: public, max-age=3600

/app.js
  Cache-Control: public, max-age=3600
